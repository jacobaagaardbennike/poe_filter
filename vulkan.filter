    Class == "Amulets" "Belts" "Boots" "Rings" "Wands"
    Rarity Rare
    AreaLevel <= 40
    Continue
  Show
    Class == "Sceptres"
    Rarity Rare
    AreaLevel < 73
    Continue
  Show
    BaseType "Citrine Amulet" "Jade Amulet" "Lapis Amulet" "Marble Amulet" "Onyx Amulet" "Turquoise Amulet" "Leather Belt" "Stygian Vise" "Amethyst Ring" "Opal Ring" "Prismatic Ring" "Ruby Ring" "Two-Stone Ring" "Vermillion Ring" "Void Sceptre" "Opal Sceptre"

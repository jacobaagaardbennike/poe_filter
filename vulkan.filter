####################################################################################################
########## Maps
####################################################################################################
Show
	Class == "Maps"
	Rarity Unique

Show
  Class == "Contracts"

Show 
  Class "Blueprints" "Breachstones" "Expedition Logbooks" "Memories" "Sanctum Research"

Show 
  Class "Maps"
  ShapedMap True

Show 
  Class "Maps"
  ElderMap True
  
Show 
  Class "Maps"
  BlightedMap True

Show 
  Class "Maps"
  UberBlightedMap True

Show 
  Class "Maps"
  HasImplicitMod True

Show 
  Class "Maps"
  AnyEnchantment True

Show
	Class == "Maps"
	MapTier >= 16

Show
	Class == "Maps"
	MapTier <= 15
  MapTier >= 14


##################################################
########## Maps: Hide + League Start
##################################################
Hide
	Class == "Maps"
	MapTier < 16
  Continue
  Show
	  Class == "Maps"
	  MapTier <= 13
    AreaLevel < 83
    Continue



##################################################
########## Items: Hide + League Start
##################################################
Show
  LinkedSockets >= 6
  SetFontSize 45


Show
  BaseType  "Citrine Amulet" "Jade Amulet" "Marble Amulet" "Onyx Amulet" "Turquoise Amulet" "Leather Belt" "Stygian Vise" "Amethyst Ring" "Opal Ring" "Two-Stone Ring" "Vermillion Ring" "Void Sceptre" "Opal Sceptre"
  ItemLevel >= 84
  # AreaLevel <= 81
  Rarity Rare
  SetFontSize 45

Show
  BaseType "Boots" "Gloves" "Helmets" "Shields"
  Rarity Rare
  ItemLevel >= 84
  # AreaLevel <= 81
  BaseArmour > 1
  SetFontSize 45

Show
  BaseType "Body Armours"
  Rarity Rare
  LinkedSockets == 5
  # AreaLevel < 81
  BaseArmour > 1
  BaseEnergyShield > 1
  SetFontSize 45

Hide
  Class == "Bows" "Claws" "Daggers" "One Hand Axes" "One Hand Maces" "One Hand Swords" "Quivers" "Rune Daggers" "Sceptres" "Shields" "Staves" "Thrusting One Hand Swords" "Two Hand Axes" "Two Hand Maces" "Two Hand Swords" "Wands" "Warstaves" "Body Armours" "Boots" "Gloves" "Helmets" "Amulets" "Belts" "Rings"
  Rarity Normal Magic Rare
  AreaLevel > 4
  SetFontSize 45
  Continue
  Show
    Class == "Daggers" "One Hand Axes" "One Hand Maces" "One Hand Swords" "Staves" "Thrusting One Hand Swords" "Warstaves"
    Rarity Normal
    AreaLevel <= 6
    Width == 1
    SetFontSize 45
    Continue
  Show
    Class == "Amulets" "Belts" "Rings"
    Rarity Normal
    AreaLevel <= 12
    SetFontSize 45
    Continue
  Show
    Class == "Amulets" "Belts" "Boots" "Rings" "Rune Daggers" "Sceptres" "Wands"
    Rarity Magic
    AreaLevel <= 12
    SetFontSize 45
    Continue
  Show
    Class == "Sceptres" "Wands" "Body Armours" "Boots" "Gloves" "Helmets" "Shields"
    LinkedSockets => 3
    Rarity Normal Magic Rare
    AreaLevel <= 16
    SetFontSize 45
    Continue
  Show
    Class == "Sceptres" "Wands" "Body Armours" "Boots" "Gloves" "Helmets" "Shields"
    SocketGroup >= 3BBR 3RRB 3BBB
    Rarity Normal Magic Rare
    ItemLevel < 25
    SetFontSize 45
    Continue
  Show
    Class == "Body Armours" "Boots" "Gloves" "Helmets"
    SocketGroup >= 4BBBR 4GGBR 4BBBB 4GG 4RR
    Rarity Normal Magic Rare
    AreaLevel < 68
    SetFontSize 45
    Continue
  Show # Chromatic 1
    Class == "Claws" "Daggers" "Rune Daggers" "Shields" "Wands" "Boots" "Gloves" "Helmets"
    SocketGroup >= 3RGB
    Rarity Normal Magic Rare
    AreaLevel < 68
    Height <= 2
    SetFontSize 45
    Continue
  Show # Chromatic 2
    Class == "One Hand Axes" "One Hand Maces" "One Hand Swords" "Sceptres" "Staves" "Thrusting One Hand Swords" "Two Hand Swords" "Warstaves"
    SocketGroup >= 3RGB
    Rarity Normal Magic Rare
    AreaLevel < 68
    Width <= 1
    SetFontSize 45
    Continue
  Show
    Class == "Amulets" "Belts" "Boots" "Rings" "Wands"
    Rarity Rare
    AreaLevel <= 40
    SetFontSize 45
    Continue
  Show
    Class == "Sceptres"
    Rarity Rare
    AreaLevel < 73
    SetFontSize 45
    Continue
  Show
    BaseType "Citrine Amulet" "Jade Amulet" "Lapis Amulet" "Marble Amulet" "Onyx Amulet" "Turquoise Amulet" "Leather Belt" "Stygian Vise" "Amethyst Ring" "Opal Ring" "Prismatic Ring" "Ruby Ring" "Two-Stone Ring" "Vermillion Ring" "Void Sceptre" "Opal Sceptre"
    Rarity Rare
    AreaLevel < 81
    SetFontSize 45
    Continue
  Show
    BaseType "Boots" "Gloves" "Helmets" "Shields"
    Rarity Rare
    SocketGroup >= 4BBBR 4GGBR 4BBBB 4GG 4RR
    AreaLevel < 81
    BaseArmour > 1
    SetFontSize 45
    Continue
  Show
    BaseType "Body Armours"
    Rarity Rare
    SocketGroup >= 4BBBR 4GGBR 4BBBB 4GG 4RR
    AreaLevel < 81
    BaseArmour > 1
    BaseEnergyShield > 1
    LinkedSockets >= 4
    SetFontSize 45



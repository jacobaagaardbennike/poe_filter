####################################################################################################
########## Important Stuff
####################################################################################################
Show 
  Class "Atlas Upgrade Items" "Fishing Rods" "Hideout Doodads" "Leaguestones" "Microtransactions" "Misc Map Items" "Pantheon Souls" "Vault Keys"
  SetFontSize 45

####################################################################################################
########## Maps
####################################################################################################
Show
	Class == "Maps"
	Rarity Unique
  SetFontSize 45

Show
  Class == "Contracts"

Show 
  Class "Blueprints" "Breachstones" "Expedition Logbooks" "Memories" "Sanctum Research"
  SetFontSize 45

Show 
  Class "Maps"
  ShapedMap True
  SetFontSize 45

Show 
  Class "Maps"
  ElderMap True
  SetFontSize 45
  
Show 
  Class "Maps"
  BlightedMap True
  SetFontSize 45

Show 
  Class "Maps"
  UberBlightedMap True
  SetFontSize 45

Show 
  Class "Maps"
  HasImplicitMod True
  SetFontSize 45

Show 
  Class "Maps"
  AnyEnchantment True
  SetFontSize 45

Show
	Class == "Maps"
	MapTier >= 16
  SetFontSize 45

##################################################
########## Maps: Hide + League Start
##################################################
Hide
	Class == "Maps"
	MapTier < 16
  Continue
  Show
	  Class == "Maps"
	  MapTier <= 13
    AreaLevel < 83
    SetFontSize 45
    Continue
  Show
	  Class == "Maps"
	  MapTier >= 14
    MapTier <= 15
    # AreaLevel < 83
    SetFontSize 45


